rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Dashboard Administrateur : accès lecture seule cross-utilisateurs,
    // gardé par un custom claim Firebase (backend/scripts/set_admin_claim.py).
    // N'affecte jamais les règles d'isolation existantes ci-dessous (sémantique OR).
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Requêtes collectionGroup('users') / collectionGroup('guitar_deals') pour l'admin.
    match /{path=**}/users/{userId} {
      allow read: if isAdmin();
    }
    match /{path=**}/guitar_deals/{dealId} {
      allow read: if isAdmin();
    }

    // Snapshot agrégé quotidien (volume, coût estimé) écrit par le backend (Admin SDK bypass).
    match /artifacts/{appId}/admin_stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Seul le propriétaire authentifié accède à ses propres données.
    // Le backend (Admin SDK) bypass ces règles par design — pas d'impact serveur.
    // Le document utilisateur lui-même (botStatus, config, etc.)
    match /artifacts/{appId}/users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Toutes les sous-collections (guitar_deals, commands, cities, logs)
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Catalogue de villes partagé entre tous les utilisateurs.
    // Tout user authentifié peut lire et enrichir le catalogue (ajout uniquement).
    // La suppression est réservée au backend (Admin SDK bypass ces règles).
    match /artifacts/{appId}/cities/{cityId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Protection du document racine de l'application (lecture seule authentifiée)
    match /artifacts/{appId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Annonces partagées publiquement (lecture sans auth, écriture auth uniquement)
    match /shared_deals/{dealId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

  }
}
