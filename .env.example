# ============================================================================
# Guitar Hunter AI — Configuration Exemple (.env.example)
# ============================================================================
# Copier ce fichier en .env et remplir les valeurs avec votre configuration.
# NE PAS commiter le fichier .env réel (secrets).

# --- Backend (Python) ---
GEMINI_API_KEY=votre-clé-api-gemini
FACEBOOK_ACCESS_TOKEN=votre-token-facebook
APP_ID_TARGET=app-id-firebase
USER_IDS_TARGET=uid1,uid2,uid3
FIREBASE_KEY_PATH=backend/config/serviceAccountKey.json
FIREBASE_STORAGE_BUCKET=votre-bucket.firebasestorage.app
NTFY_TOPIC=votre-ntfy-topic
IMAGE_RETENTION_REJECTED_DAYS=30

# --- Robustesse Multi-Utilisateur (Session 2026-03-29) ---
MAX_CONCURRENT_BROWSERS=3                    # Limite navigateurs Playwright simultanés
VITE_ADMIN_EMAIL=admin@example.com           # Email admin pour migrations (voir firestoreService.js)

# --- Frontend (React / Vite) ---
VITE_APP_ID_TARGET=app-id-firebase
VITE_USER_ID_TARGET=old-static-user-id       # Ancien UID pour migration (si applicable)
VITE_ADMIN_EMAIL=admin@example.com           # Email admin pour migrations
VITE_FIREBASE_API_KEY=votre-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=votre-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=votre-project-id
VITE_FIREBASE_STORAGE_BUCKET=votre-bucket.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdefg
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXX

# --- Mode Offline (Développement) ---
# OFFLINE_MODE=true                          # Désactiver à des fins de test local
